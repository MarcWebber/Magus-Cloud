{
  "cluster": {
    "mode": "shared-storage",
    "gatewayPublicUrl": "http://localhost:3000",
    "nodes": [
      {
        "id": "node-local",
        "baseUrl": "http://localhost:3000",
        "enabled": true,
        "tags": ["primary", "development"]
      }
    ]
  },
  "storage": {
    "sharedRootDir": "./uploads",
    "totalCapacityGb": 500,
    "reserveFreeGb": 20,
    "defaultUserQuotaGb": 20,
    "quotaEnabled": true
  },
  "users": [
    {
      "username": "admin",
      "displayName": "Administrator",
      "quotaGb": 20,
      "enabled": true,
      "homeDir": "admin"
    },
    {
      "username": "test",
      "displayName": "Test User",
      "quotaGb": 20,
      "enabled": true,
      "homeDir": "test"
    }
  ],
  "backup": {
    "snapshotRootDir": "./snapshots",
    "retentionCount": 10,
    "compression": "tar.gz",
    "allowUserExport": true,
    "verifyAfterCreate": true
  },
  "ui": {
    "appName": "Magus Cloud",
    "supportUrl": "",
    "defaultLocale": "zh-CN"
  }
}
