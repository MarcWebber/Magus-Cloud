    "@types/react-router-dom": "^5.3.3",
    "cross-env": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
