NODE_ENV=production

# Public URLs
MAGUS_PUBLIC_APP_URL=http://localhost:3000
MAGUS_PUBLIC_API_URL=http://localhost:3000
MAGUS_DATABASE_URL=postgresql://magus:magus@localhost:5432/magus

# Admin session
MAGUS_ADMIN_USERNAME=admin
MAGUS_ADMIN_PASSWORD=change-me
MAGUS_SESSION_SECRET=change-me

# Storage and config
MAGUS_STORAGE_ROOT=/www/wwwroot
MAGUS_DEV_STORAGE_ROOT=./uploads
MAGUS_SERVICE_CONFIG=./config/magus.config.json
MAGUS_CLOUD_CONFIG=./config/cloud.config.json

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ngrok
NGROK_API_URL=http://localhost:4040
NGROK_AUTHTOKEN=
NGROK_DOMAIN=
NGROK_TUNNEL_NAME=magus-cloud
NGROK_ADDR=app:3000

# UI
MAGUS_APP_NAME=Magus Cloud
MAGUS_SUPPORT_URL=
